# ===============================================
#  Zusammengestellt für Java, Maven & gängige IDEs
# ===============================================

# 1. Maven-spezifische Dateien und Verzeichnisse
# -----------------------------------------------
# Das 'target'-Verzeichnis enthält alle Build-Artefakte (kompilierte Klassen, Jars, etc.)
target/

# Log-Dateien von Maven
*.log
pom.xml.tag
pom.xml.releaseBackup
pom.xml.versionsBackup
pom.xml.next
release.properties
dependency-reduced-pom.xml
buildNumber.properties

# Maven-Wrapper-Dateien (wenn man sie nicht für jeden Entwickler erzwingen will)
# Meistens will man diese aber committen, daher auskommentiert.
# .mvn/
# mvnw
# mvnw.cmd


# 2. IDE-spezifische Konfigurationsdateien
# ------------------------------------------

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/
atlassian-ide-plugin.xml

# Eclipse
.classpath
.project
.settings/
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib

# NetBeans
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# VS Code
.vscode/


# 3. Betriebssystem-spezifische Dateien
# ---------------------------------------
# macOS
.DS_Store
.AppleDouble
.LSOverride
Thumbs.db
ehthumbs.db

# Windows
# Desktop.ini
# thumbs.db


# 4. Allgemeine und Sonstige Dateien
# ------------------------------------
# Log-Dateien
*.log
logs/

# Lokale Konfigurationsdateien
# (z.B. wenn man Passwörter lokal speichert, die nicht ins Repo sollen)
local.properties

# Komprimierte Dateien, die oft als Backup erstellt werden
*.zip
*.tar
*.gz
*.rar

# hs_err_pid* Dateien, die von der JVM bei einem Crash erstellt werden
hs_err_pid*

./htmlReport